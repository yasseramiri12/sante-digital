        {
          "name": "GET Demandes by Statut — EN_ATTENTE",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/laboratoire/demandes/statut/EN_ATTENTE", "host": ["{{baseUrl}}"], "path": ["api","laboratoire","demandes","statut","EN_ATTENTE"] },
            "description": "Valid values: EN_ATTENTE | EN_COURS | TERMINE"
          }
        },
        {
          "name": "POST Create Demande d'Analyse",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"consultationId\": 1,\n  \"patientId\": 1,\n  \"typeAnalyse\": \"NFS - Numération Formule Sanguine\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/laboratoire/demandes", "host": ["{{baseUrl}}"], "path": ["api","laboratoire","demandes"] },
            "description": "Required: consultationId, patientId, typeAnalyse.\nstatut is auto-set to EN_ATTENTE.\nReturns HTTP 201."
          }
        },
        {
          "name": "PUT Update Statut Demande — @RequestParam",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/laboratoire/demandes/{{demandeId}}/statut?statut=EN_COURS",
              "host": ["{{baseUrl}}"],
              "path": ["api","laboratoire","demandes","{{demandeId}}","statut"],
              "query": [{ "key": "statut", "value": "EN_COURS" }]
            },
            "description": "IMPORTANT: statut is a @RequestParam (query string), NOT a body.\nValid values: EN_ATTENTE | EN_COURS | TERMINE\nExample: PUT /api/laboratoire/demandes/1/statut?statut=EN_COURS"
          }
        },
        {
          "name": "DELETE Demande",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/laboratoire/demandes/{{demandeId}}", "host": ["{{baseUrl}}"], "path": ["api","laboratoire","demandes","{{demandeId}}"] },
            "description": "Returns HTTP 204 No Content."
          }
        }
      ]
    },

