          "name": "GET Ordonnances by Statut — ACTIVE",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/ordonnances/statut/ACTIVE", "host": ["{{baseUrl}}"], "path": ["api","ordonnances","statut","ACTIVE"] },
            "description": "Valid values: EN_ATTENTE | ACTIVE | USED | EXPIRED"
          }
        },
        {
          "name": "POST Create Ordonnance",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"consultationId\": 1,\n  \"patientId\": 1,\n  \"dateExpiration\": \"2025-11-14\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/ordonnances", "host": ["{{baseUrl}}"], "path": ["api","ordonnances"] },
            "description": "Required: consultationId, patientId, dateExpiration (YYYY-MM-DD).\nstatut is auto-set to ACTIVE by @PrePersist.\nReturns HTTP 201."
          }
        },
        {
          "name": "PUT Close Ordonnance (→ USED)",
          "request": {
            "method": "PUT",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/ordonnances/{{ordonnanceId}}/close", "host": ["{{baseUrl}}"], "path": ["api","ordonnances","{{ordonnanceId}}","close"] },
            "description": "Transitions statut: ACTIVE → USED. No request body needed."
          }
        },
        {
          "name": "PUT Expire Ordonnance (→ EXPIRED)",
          "request": {
            "method": "PUT",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/ordonnances/{{ordonnanceId}}/expire", "host": ["{{baseUrl}}"], "path": ["api","ordonnances","{{ordonnanceId}}","expire"] },
            "description": "Transitions statut: ACTIVE → EXPIRED. No request body needed."
          }
        },
        {
          "name": "DELETE Ordonnance",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/ordonnances/{{ordonnanceId}}", "host": ["{{baseUrl}}"], "path": ["api","ordonnances","{{ordonnanceId}}"] },
            "description": "Returns HTTP 204 No Content."
          }
        }
      ]
    },

