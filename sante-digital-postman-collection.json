{
  "info": {
    "name": "SanteDigital — API Complete",
    "description": "All 50 endpoints across 7 modules. Import this file into Postman then set the `baseUrl` variable (default: http://localhost:8080). Run requests top-to-bottom per folder — CREATE first, then use the returned IDs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "sante-digital-v2"
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:8080", "type": "string" },
    { "key": "patientId",      "value": "1",  "type": "string" },
    { "key": "medecinId",      "value": "1",  "type": "string" },
    { "key": "consultationId", "value": "1",  "type": "string" },
    { "key": "ordonnanceId",   "value": "1",  "type": "string" },
    { "key": "demandeId",      "value": "1",  "type": "string" },
    { "key": "resultatId",     "value": "1",  "type": "string" },
    { "key": "pharmacieId",    "value": "1",  "type": "string" },
    { "key": "dispensationId", "value": "1",  "type": "string" }
  ],
  "item": [

    {
      "name": "01 — Patients",
      "description": "6 endpoints — GET /api/patients | POST | GET /{id} | GET /nin/{nin} | PUT /{id} | DELETE /{id}",
      "item": [
        {
          "name": "GET All Patients",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/patients", "host": ["{{baseUrl}}"], "path": ["api","patients"] },
            "description": "Returns list of all patients."
          }
        },
        {
          "name": "GET Patient by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/patients/{{patientId}}", "host": ["{{baseUrl}}"], "path": ["api","patients","{{patientId}}"] },
            "description": "Returns one patient by primary key."
          }
        },
        {
          "name": "GET Patient by NIN",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/patients/nin/PB344551", "host": ["{{baseUrl}}"], "path": ["api","patients","nin","PB344551"] },
            "description": "Returns patient by National Identification Number."
          }
        },
        {
          "name": "POST Create Patient",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nin\": \"TEST001\",\n  \"nom\": \"BENALI\",\n  \"prenom\": \"Hamid\",\n  \"dateNaissance\": \"1990-03-15\",\n  \"groupeSanguin\": \"O+\",\n  \"telephone\": \"0661234567\",\n  \"email\": \"hamid.benali@gmail.com\",\n  \"adresse\": \"12 Rue des Fleurs, Casablanca\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/patients", "host": ["{{baseUrl}}"], "path": ["api","patients"] },
            "description": "Required: nin, nom, prenom, dateNaissance. Optional: groupeSanguin, telephone, email, adresse.\nReturns HTTP 201."
          }
        },
        {
          "name": "PUT Update Patient",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nin\": \"TEST001\",\n  \"nom\": \"BENALI\",\n  \"prenom\": \"Hamid\",\n  \"dateNaissance\": \"1990-03-15\",\n  \"groupeSanguin\": \"A+\",\n  \"telephone\": \"0699999999\",\n  \"email\": \"hamid.updated@gmail.com\",\n  \"adresse\": \"99 Nouvelle Adresse, Rabat\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/patients/{{patientId}}", "host": ["{{baseUrl}}"], "path": ["api","patients","{{patientId}}"] },
            "description": "Full replacement of patient fields. nin cannot be changed by logic (validation in service)."
          }
        },
        {
          "name": "DELETE Patient",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/patients/{{patientId}}", "host": ["{{baseUrl}}"], "path": ["api","patients","{{patientId}}"] },
            "description": "Returns HTTP 204 No Content."
          }
        }
      ]
    },

