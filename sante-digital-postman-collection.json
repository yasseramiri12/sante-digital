              "mode": "raw",
              "raw": "{\n  \"demandeId\": 1,\n  \"valeursJson\": \"{\\\"hemoglobine\\\": \\\"14.2 g/dL\\\", \\\"leucocytes\\\": \\\"6200 /mm3\\\", \\\"plaquettes\\\": \\\"250000 /mm3\\\"}\",\n  \"alerteCritique\": false,\n  \"fichierUrl\": \"/files/resultat-1.pdf\"\n}",
              "options": { "raw": { "language": "json" } }
