        {
          "name": "DELETE Résultat",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/laboratoire/resultats/{{resultatId}}", "host": ["{{baseUrl}}"], "path": ["api","laboratoire","resultats","{{resultatId}}"] },
            "description": "Résultats are immutable once published — use DELETE only for corrections. Returns HTTP 204."
          }
        }
      ]
    },

